  "rules": {
    "max_saturation_percent": 60,
    "min_lighting_variation": 0.1,
    "no_pure_white": true,
    "no_pure_black": true,
    "warm_dominant": 0.7,
    "cool_accent": 0.3,
    "pastel_threshold": 0.6,
    "min_contrast_ratio_wcag": 4.5
  },

  "use_guidelines": {
    "scene_composition": [
      "60% of visible surface = pastel/neutral",
      "30% = warm accent (wood, fabric, light)",
      "10% = cool shadow + sky",
      "0% = pure primary color (saturated)"
    ],
    "material_creation": [
      "Always use variation array",
      "Always specify roughness range",
      "Never set metallic > 1.0",
      "Always add subtle wear pattern"
    ],
    "lighting_setup": [
      "Match time-of-day preset to zone",
      "Override only for narrative purpose",
      "Never use pure white sun",
      "Shadow must have color tint"
    ]
  }
}
