    "default_color_space": "sRGB",
    "default_normal_space": "Linear",
    "use_HDR_environment": true,
    "use_pmremGenerator": true,
    "max_texture_size": 2048,
    "min_texture_size": 128,
    "default_anisotropy": 4,
    "preferred_format": "PNG"
  },

  "validation_rules": [
    "color.saturation <= 0.6",
    "roughness.metal >= 0.85",
    "roughness.glass <= 0.15",
    "no_pure_colors",
    "no_forbidden_hex (see forbidden_elements.md)"
  ]
