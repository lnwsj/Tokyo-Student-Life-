{
  "name": "Tokyo Student Life — Time of Day",
  "version": "1.0",
  "description": "5 lighting presets — ใช้ขับเคลื่อน mood ของแต่ละ scene",

  "presets": {

    "morning_home": {
      "name": "Morning Home",
      "name_jp": "朝のホーム",
      "name_th": "เช้า (บ้าน)",
      "time": "07:00",
      "primary_zone": 1,
      "description": "แสงเช้านุ่ม ผ่านม่าน เริ่มต้นวันใหม่",

      "sun": {
        "color": "#FFD194",
        "color_kelvin": 4000,
        "intensity": 1.0,
        "elevation": 25,
        "azimuth": 90
      },
      "sky": {
        "color": "#D6EEF5",
        "intensity": 0.4
      },
      "ambient": {
        "sky_color": "#B8DCE6",
        "ground_color": "#8B6F47",
        "intensity": 0.35
      },
      "fog": {
        "color": "#F5F0E6",
        "density": 0.005,
        "near": 30,
        "far": 100
      },
      "post_processing": {
        "exposure": 1.1,
        "contrast": 1.05,
        "saturation": 0.85,
        "warmth": 0.1,
        "bloom": { "strength": 0.4, "radius": 0.4, "threshold": 0.85 },
        "vignette": { "strength": 0.2, "smoothness": 0.5 },
        "grain": { "strength": 0.05, "size": 0.5 }
      },
      "mood": "อบอุ่น นุ่ม เริ่มวันใหม่",
      "sound_cue": "นกเช้า + หม้อข้าวเดือด"
    },

    "noon_school": {
      "name": "Noon School",
      "name_jp": "正午の学校",
      "name_th": "เที่ยง (โรงเรียน)",
      "time": "12:00",
      "primary_zone": 2,
      "description": "แสงเที่ยงสดใส สว่าง มีชีวิตชีวา",

      "sun": {
        "color": "#FFFAF0",
        "color_kelvin": 5500,
        "intensity": 1.3,
        "elevation": 70,
        "azimuth": 180
      },
      "sky": {
        "color": "#B8DCE6",
        "intensity": 0.45
      },
      "ambient": {
        "sky_color": "#D6EEF5",
        "ground_color": "#8B6F47",
        "intensity": 0.40
      },
      "fog": {
        "color": "#FFFFFF",
        "density": 0.002,
        "near": 50,
        "far": 200
      },
      "post_processing": {
        "exposure": 1.15,
        "contrast": 1.0,
        "saturation": 0.85,
        "warmth": 0.0,
        "bloom": { "strength": 0.3, "radius": 0.5, "threshold": 0.90 },
        "vignette": { "strength": 0.15, "smoothness": 0.5 },
        "grain": { "strength": 0.03, "size": 0.5 }
      },
      "mood": "สดใส มีชีวิตชีวา กระปรี้กระเปร่า",
      "sound_cue": "ระฆังโรงเรียน + นักเรียนคุยกัน"
    },

    "evening_station": {
      "name": "Evening Station",
      "name_jp": "夕方の駅",
      "name_th": "เย็น (สถานี)",
      "time": "17:30",
      "primary_zone": 3,
      "description": "Golden hour อบอุ่นสุด shadow ยาว nostalgic",

      "sun": {
        "color": "#FF8C42",
        "color_kelvin": 3200,
        "intensity": 1.2,
        "elevation": 15,
        "azimuth": 270
      },
      "sky": {
        "color": "#F5C088",
        "intensity": 0.4
      },
      "ambient": {
        "sky_color": "#E8A878",
        "ground_color": "#8B6F47",
        "intensity": 0.30
      },
      "fog": {
        "color": "#FFD194",
        "density": 0.008,
        "near": 20,
        "far": 80
      },
      "post_processing": {
        "exposure": 1.1,
        "contrast": 1.1,
        "saturation": 0.90,
        "warmth": 0.2,
        "bloom": { "strength": 0.5, "radius": 0.4, "threshold": 0.80 },
        "vignette": { "strength": 0.3, "smoothness": 0.5 },
        "grain": { "strength": 0.06, "size": 0.5 }
      },
      "mood": "Golden hour nostalgic อบอุ่นสุด",
      "sound_cue": "รถไฟ + คนคุย + รถผ่าน"
    },

    "night_shopping": {
      "name": "Night Shopping",
      "name_jp": "夜の商店街",
      "name_th": "ค่ำ (ช้อปปิ้ง)",
      "time": "19:00",
      "primary_zone": 4,
      "description": "Neon warm subtle คึกคัก cozy crowd",

      "sun": {
        "color": null,
        "intensity": 0,
        "elevation": 0,
        "azimuth": 0
      },
      "sky": {
        "color": "#2D2840",
        "intensity": 0.15
      },
      "ambient": {
        "sky_color": "#5A4F7A",
        "ground_color": "#4A3F5C",
        "intensity": 0.25
      },
      "fog": {
        "color": "#1A1A2E",
        "density": 0.012,
        "near": 15,
        "far": 70
      },
      "post_processing": {
        "exposure": 1.0,
        "contrast": 1.15,
        "saturation": 0.95,
        "warmth": 0.05,
        "bloom": { "strength": 0.8, "radius": 0.5, "threshold": 0.70 },
        "vignette": { "strength": 0.4, "smoothness": 0.5 },
        "grain": { "strength": 0.08, "size": 0.5 }
      },
      "neon_settings": {
        "enabled": true,
        "max_signs": 8,
        "color_palette": ["#FF6B35", "#E55A25", "#FF7C45", "#FFB347"],
        "intensity": 0.5,
        "emissive_boost": 1.5
      },
      "mood": "คึกคัก cozy มีชีวิตชีวา",
      "sound_cue": "เพลงจากร้าน + คนคุย + จานชาม"
    },

    "sunset_shrine": {
      "name": "Sunset Shrine",
      "name_jp": "夕暮れの神社",
      "name_th": "เย็น (ศาลเจ้า)",
      "time": "16:00",
      "primary_zone": 5,
      "description": "สงบ wabi-sabi เหมือนเวลาหยุด",

      "sun": {
        "color": "#FFB347",
        "color_kelvin": 3500,
        "intensity": 1.1,
        "elevation": 20,
        "azimuth": 270
      },
      "sky": {
        "color": "#F5C088",
        "intensity": 0.4
      },
      "ambient": {
        "sky_color": "#E8A878",
        "ground_color": "#8B6F47",
        "intensity": 0.32
      },
      "fog": {
        "color": "#FFD194",
        "density": 0.006,
        "near": 25,
        "far": 90
      },
      "post_processing": {
        "exposure": 1.1,
        "contrast": 1.05,
        "saturation": 0.88,
        "warmth": 0.15,
        "bloom": { "strength": 0.4, "radius": 0.4, "threshold": 0.85 },
        "vignette": { "strength": 0.25, "smoothness": 0.5 },
        "grain": { "strength": 0.05, "size": 0.5 }
      },
      "mood": "สงบ wabi-sabi เวลาหยุด",
      "sound_cue": "ระฆัง + น้ำไหล + นก"
    }
  },

  "zone_to_time_mapping": {
    "1": "morning_home",
    "2": "noon_school",
    "3": "evening_station",
    "4": "night_shopping",
    "5": "sunset_shrine"
  },

  "transition": {
    "duration_seconds": 30,
    "easing": "ease-in-out",
    "interpolate": ["sun.color", "sun.intensity", "ambient.intensity", "fog.density", "fog.color", "exposure"]
  }
}
